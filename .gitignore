# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class
*.pyo

# Environment variables
.env
.env.*

# Virtual environments
venv/
.venv/
env/
ENV/

# Uploaded user files – keep the directory itself but not its contents
uploads/*
!uploads/.gitkeep

# Password hash file generated at runtime
password.hash

# OS artefacts
.DS_Store
Thumbs.db
desktop.ini

# IDE / editor
.vscode/
.idea/
*.swp
*.swo

# Distribution / packaging
dist/
build/
*.egg-info/
